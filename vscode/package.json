{
  "name": "cvr-name-coder",
  "displayName": "cvr.name.coder",
  "description": "Autonomous AI coding agent for VS Code with persistent memory, Goal Loop, Project Oracle RAG, design systems, code review, browser automation, vision, cron tasks, Agent Marketplace, team sync, MCP tools/server, and local or cloud LLM support.",
  "version": "1.5.59",
  "publisher": "cvr-name",
  "author": {
    "name": "cvr.name",
    "url": "https://github.com/cvr-name"
  },
  "license": "MIT",
  "icon": "public/app-icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "capabilities": {
    "workspace": {
      "read": true,
      "write": true
    }
  },
  "categories": [
    "AI",
    "Machine Learning",
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "ai",
    "coding agent",
    "autonomous",
    "chat",
    "gemini",
    "ollama",
    "llama.cpp",
    "local ai",
    "offline",
    "mcp",
    "mcp server",
    "code assistant",
    "code review",
    "rag",
    "goal loop",
    "browser automation",
    "playwright",
    "vision",
    "design systems",
    "agent marketplace",
    "team sync",
    "cron",
    "llm",
    "deepseek",
    "groq"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cvr-name/cvr.name.coder"
  },
  "bugs": {
    "url": "https://github.com/cvr-name/cvr.name.coder/issues"
  },
  "galleryBanner": {
    "color": "#0F0F11",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:cvr.webview",
    "onCommand:cvr.launch",
    "onCommand:cvr.openSidebar",
    "onCommand:cvr.inlineEdit"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cvr.launch",
        "title": "cvr.name: Launch Dashboard",
        "category": "cvr.name"
      },
      {
        "command": "cvr.openSidebar",
        "title": "cvr.name: Open Sidebar",
        "category": "cvr.name"
      },
      {
        "command": "cvr.clearHistory",
        "title": "cvr.name: Clear History & Memory",
        "category": "cvr.name"
      },
      {
        "command": "cvr.inlineEdit",
        "title": "cvr.name: Inline Edit Selection",
        "category": "cvr.name"
      },
      {
        "command": "cvr.startMcpServer",
        "title": "cvr.name: Start MCP Server",
        "category": "cvr.name"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cvr-explorer",
          "title": "cvr.name",
          "icon": "public/app-icon.png"
        }
      ]
    },
    "views": {
      "cvr-explorer": [
        {
          "type": "webview",
          "id": "cvr.webview",
          "name": "cvr.name Kernel"
        }
      ]
    },
    "keybindings": [
      {
        "command": "cvr.openSidebar",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c",
        "when": "editorTextFocus"
      },
      {
        "command": "cvr.inlineEdit",
        "key": "ctrl+k ctrl+k",
        "mac": "cmd+k cmd+k",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "cvr.name.coder",
      "properties": {
        "cvr.completion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline code completion"
        },
        "cvr.completion.provider": {
          "type": "string",
          "default": "",
          "enum": [
            "gemini",
            "openai",
            "local",
            "custom"
          ],
          "description": "Provider for inline completions"
        },
        "cvr.completion.model": {
          "type": "string",
          "default": "",
          "description": "Model for inline completions (use cheap/fast models)"
        },
        "cvr.completion.debounceMs": {
          "type": "number",
          "default": 150,
          "description": "Debounce delay in ms before fetching completion"
        },
        "cvr.diff.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show diff preview before applying file changes"
        },
        "cvr.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inline diagnostics after AI file edits"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "bump": "npm version patch --no-git-tag-version",
    "package": "npm run bump && vsce package"
  },
  "devDependencies": {
    "@google/genai": "^1.29.0",
    "@types/express": "^4.17.21",
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.9.1",
    "dotenv": "^17.2.3",
    "esbuild": "^0.25.2",
    "express": "^4.21.2",
    "playwright": "^1.60.0",
    "typescript": "^4.9.5"
  }
}
